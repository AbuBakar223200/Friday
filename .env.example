# Copy this file to .env and paste one provider key.
# Keep .env private. Do not commit real API keys.

# Provider selection:
# - auto: use the first configured provider in this order:
#   Gemini, OpenAI, Anthropic, OpenRouter, Ollama
# - or set one explicitly: gemini, openai, anthropic, openrouter, ollama
AI_PROVIDER=auto

# Gemini (works now with the existing google-genai package)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_TEXT_MODELS=gemini-2.5-flash-lite,gemini-2.5-flash,gemini-2.0-flash
GEMINI_VISION_MODELS=gemini-2.5-flash,gemini-2.0-flash

# OpenAI
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5
OPENAI_VISION_MODEL=gpt-5

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_TEXT_MODEL=claude-sonnet-4-20250514
ANTHROPIC_VISION_MODEL=claude-sonnet-4-20250514

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_TEXT_MODEL=openrouter/auto
OPENROUTER_VISION_MODEL=openrouter/auto

# Ollama local models, no API key required. Start Ollama first.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=

# Speech capture tuning.
# Increase PHRASE_TIME_LIMIT for longer commands.
# Increase PAUSE_THRESHOLD if Friday cuts you off when you pause mid-sentence.
LISTEN_TIMEOUT=5
PHRASE_TIME_LIMIT=30
WAKE_PHRASE_TIME_LIMIT=8
PAUSE_THRESHOLD=1.6
NON_SPEAKING_DURATION=0.6
PHRASE_THRESHOLD=0.3
